{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "test:e2e": "playwright test",
    "widget:build": "cd widget && npm install && npm run build",
    "widget:deploy": "pnpm widget:build && node --env-file=.env scripts/upload-widget.mjs",
    "widget:dev": "cd widget && npm install && npm run dev"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@iconify-json/lucide": "^1.2.98",
    "@iconify-json/simple-icons": "^1.2.74",
    "@nuxt/ui": "^4.6.1",
    "@nuxtjs/supabase": "2.0.4",
    "@nuxtjs/tailwindcss": "6.14.0",
    "@pinia/nuxt": "^0.11.3",
    "dompurify": "^3.3.3",
    "gsap": "^3.14.2",
    "js-tiktoken": "^1.0.21",
    "lenis": "^1.3.18",
    "markdown-it": "^14.1.1",
    "motion-v": "^2.0.1",
    "nuxt": "^4.4.2",
    "openai": "^6.32.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.2",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1035.0",
    "@axe-core/playwright": "^4.11.1",
    "@iconify-json/heroicons": "^1.2.3",
    "@nuxt/eslint": "^1.15.2",
    "@oro.ad/nuxt-claude-devtools": "^1.5.2",
    "@playwright/test": "^1.59.1",
    "@types/dompurify": "^3.2.0",
    "@types/markdown-it": "^14.1.2",
    "@vueuse/nuxt": "^14.2.1",
    "dayjs-nuxt": "^2.1.11",
    "eslint": "^10.0.3",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.5"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "reka-ui": "2.9.2"
    }
  }
}
